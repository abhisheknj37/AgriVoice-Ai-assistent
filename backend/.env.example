# Production Environment Variables for DigitalOcean
# Copy this to backend/.env and fill in your values

# Database
DB_NAME=agrivoice_prod
DB_USER=agrivoice_user
DB_PASSWORD=your-super-secure-db-password-here

# Django
DJANGO_SECRET_KEY=your-64-character-random-secret-key-here
DJANGO_SETTINGS_MODULE=agrivoice.settings_prod

# API Keys (Get from OpenAI and Sarvam AI)
OPENAI_API_KEY=sk-your-openai-api-key-here
SARVAM_API_KEY=your-sarvam-api-key-here

# Email (Use Gmail App Passwords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Domain (Replace with your actual domain)
DOMAIN=yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com